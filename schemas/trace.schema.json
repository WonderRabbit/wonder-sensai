{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wonder-sensai.local/schemas/trace.schema.json",
  "title": "레거시 프로젝트 추적 계약 (schema 2.0 — AS-IS/TO-BE 판별자 + conventions)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "scope", "evidence", "requirements", "frontends", "backends", "joins", "conventions", "unknowns"],
  "properties": {
    "schema_version": { "const": "2.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roots"],
      "properties": { "roots": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true } }
    },
    "evidence": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/evidence" } },
    "requirements": { "type": "array", "items": { "$ref": "#/$defs/requirement" } },
    "frontends": { "type": "array", "items": { "$ref": "#/$defs/frontend" } },
    "backends": { "type": "array", "items": { "$ref": "#/$defs/backend" } },
    "joins": { "type": "array", "items": { "$ref": "#/$defs/join" } },
    "conventions": { "type": "array", "items": { "$ref": "#/$defs/convention" } },
    "unknowns": { "type": "array", "items": { "$ref": "#/$defs/unknown" } },
    "unsupported": { "type": "array", "items": { "$ref": "#/$defs/unsupported" } },
    "business_entities": { "type": "array", "items": { "$ref": "#/$defs/business_fact" } },
    "business_rules": { "type": "array", "items": { "$ref": "#/$defs/business_fact" } },
    "business_flows": { "type": "array", "items": { "$ref": "#/$defs/business_fact" } },
    "business_events": { "type": "array", "items": { "$ref": "#/$defs/business_fact" } },
    "business_states": { "type": "array", "items": { "$ref": "#/$defs/business_fact" } },
    "business_invariants": { "type": "array", "items": { "$ref": "#/$defs/business_fact" } },
    "designs": { "type": "array", "items": { "$ref": "#/$defs/design" } },
    "bindings": { "type": "array", "items": { "$ref": "#/$defs/binding" } },
    "extension_requirements": { "type": "array", "items": { "$ref": "#/$defs/extension_requirement" } }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]+$" },
    "evidenceRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/id" }, "uniqueItems": true },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "layer", "path", "line", "extractor", "claim_ko", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "layer": { "enum": ["react", "vertx", "openapi", "spec"] },
        "path": { "type": "string", "minLength": 1 }, "line": { "type": "integer", "minimum": 1 },
        "extractor": { "type": "string", "minLength": 1 }, "claim_ko": { "type": "string", "minLength": 1 },
        "status": { "enum": ["exact", "unresolved", "ambiguous", "conflict"] }
      }
    },
    "requirement": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "source", "section", "keyword", "statement_ko", "evidence_ids"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "source": { "type": "string", "minLength": 1 }, "section": { "type": "string", "minLength": 1 },
        "keyword": { "enum": ["MUST", "SHOULD", "MAY"] }, "statement_ko": { "type": "string", "minLength": 1 }, "evidence_ids": { "$ref": "#/$defs/evidenceRefs" }
      }
    },
    "frontend": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "component", "route", "api_calls", "evidence_ids", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "component": { "type": "string", "minLength": 1 }, "route": { "$ref": "#/$defs/path" },
        "api_calls": { "type": "array", "items": { "$ref": "#/$defs/call" } }, "evidence_ids": { "$ref": "#/$defs/evidenceRefs" },
        "status": { "enum": ["exact", "unresolved", "ambiguous", "conflict"] }
      }
    },
    "backend": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "transport", "method", "path", "operation_id", "handler", "event_bus_address", "evidence_ids", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "transport": { "const": "http" }, "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path": { "$ref": "#/$defs/path" }, "operation_id": { "type": ["string", "null"] }, "handler": { "type": ["string", "null"] },
        "event_bus_address": { "type": ["string", "null"] }, "evidence_ids": { "$ref": "#/$defs/evidenceRefs" },
        "status": { "enum": ["exact", "unresolved", "ambiguous", "conflict"] }
      }
    },
    "path": {
      "type": "object", "additionalProperties": false, "required": ["expr", "literal", "normalized"],
      "properties": { "expr": { "type": "string", "minLength": 1 }, "literal": { "type": ["string", "null"] }, "normalized": { "type": ["string", "null"] } }
    },
    "call": {
      "type": "object", "additionalProperties": false, "required": ["method", "path", "evidence_ids", "status"],
      "properties": { "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] }, "path": { "$ref": "#/$defs/path" }, "evidence_ids": { "$ref": "#/$defs/evidenceRefs" }, "status": { "enum": ["exact", "unresolved", "ambiguous", "conflict"] } }
    },
    "join": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "method", "path_normalized", "left_id", "right_ids", "cardinality", "status", "evidence_ids"],
      "properties": {
        "id": { "$ref": "#/$defs/id" }, "kind": { "const": "http" }, "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path_normalized": { "type": ["string", "null"] }, "left_id": { "$ref": "#/$defs/id" }, "right_ids": { "type": "array", "items": { "$ref": "#/$defs/id" }, "uniqueItems": true },
        "cardinality": { "enum": ["one_to_one", "many_to_many", "unresolved"] }, "status": { "enum": ["exact", "unresolved", "ambiguous", "conflict"] }, "evidence_ids": { "$ref": "#/$defs/evidenceRefs" }
      }
    },
    "convention": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "category", "statement_ko", "examples", "evidence_ids", "status", "extractor"],
      "properties": {
        "id": { "type": "string", "pattern": "^CONV-(STACK|STRUCTURE|NAMING|API|STATE|CODINGSTD|SCAFFOLD)-[0-9]{3}$" },
        "kind": { "enum": ["asis", "tobe"] },
        "category": { "enum": ["stack", "structure", "naming", "api_pattern", "state", "coding_standard", "scaffold_pattern"] },
        "statement_ko": { "type": "string", "minLength": 1 },
        "examples": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "evidence_ids": { "$ref": "#/$defs/evidenceRefs" },
        "status": { "enum": ["exact", "unresolved", "ambiguous", "conflict"] },
        "extractor": { "type": "string", "minLength": 1 }
      }
    },
    "unknown": {
      "type": "object", "additionalProperties": false, "required": ["id", "statement_ko", "reason", "next_probe", "evidence_ids"],
      "properties": { "id": { "$ref": "#/$defs/id" }, "statement_ko": { "type": "string", "minLength": 1 }, "reason": { "type": "string", "minLength": 1 }, "next_probe": { "type": "string", "minLength": 1 }, "evidence_ids": { "$ref": "#/$defs/evidenceRefs" } }
    },
    "unsupported": {
      "type": "object", "additionalProperties": false, "required": ["id", "statement_ko", "reason"],
      "properties": { "id": { "$ref": "#/$defs/id" }, "statement_ko": { "type": "string", "minLength": 1 }, "reason": { "type": "string", "minLength": 1 } }
    },
    "business_fact": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "category", "statement_ko", "evidence_ids", "status"],
      "properties": {
        "id": { "type": "string", "pattern": "^BIZ-(ENT|RULE|FLOW|EVT|STATE|INV)-[0-9]{3}$" },
        "kind": { "enum": ["asis", "tobe"] },
        "category": { "enum": ["business_entity", "business_rule", "business_flow", "business_event", "business_state", "business_invariant"] },
        "statement_ko": { "type": "string", "minLength": 1 },
        "identifiers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "evidence_ids": { "$ref": "#/$defs/evidenceRefs" },
        "status": { "enum": ["exact", "unresolved", "ambiguous", "conflict"] }
      }
    },
    "design": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "type", "statement_ko", "requirement_ids", "follows_convention_ids", "follows_business_ids", "evidence_ids", "status"],
      "properties": {
        "id": { "type": "string", "pattern": "^DESIGN-(PAGE|SERVICE|API|ENTITY)-[0-9]{3}$" },
        "kind": { "enum": ["tobe"] },
        "type": { "enum": ["page", "service", "api", "entity"] },
        "statement_ko": { "type": "string", "minLength": 1 },
        "requirement_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "follows_convention_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "follows_business_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "evidence_ids": { "$ref": "#/$defs/evidenceRefs" },
        "status": { "enum": ["exact", "unresolved", "ambiguous", "conflict"] }
      }
    },
    "binding": {
      "type": "object", "additionalProperties": false,
      "required": ["design_id", "target_kind", "target_id", "gate"],
      "properties": {
        "design_id": { "type": "string", "minLength": 1 },
        "target_kind": { "enum": ["convention", "business"] },
        "target_id": { "type": "string", "minLength": 1 },
        "gate": { "enum": ["pass", "violation"] }
      }
    },
    "extension_requirement": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "statement_ko", "source", "evidence_ids", "status"],
      "properties": {
        "id": { "type": "string", "pattern": "^REQ-EXT-[0-9]{4}$" },
        "statement_ko": { "type": "string", "minLength": 1 },
        "source": { "enum": ["user", "elicited", "inferred"] },
        "keyword": { "enum": ["MUST", "MUST NOT", "SHOULD", "SHOULD NOT", "MAY"] },
        "evidence_ids": { "$ref": "#/$defs/evidenceRefs" },
        "status": { "enum": ["exact", "unresolved", "ambiguous", "conflict"] }
      }
    }
  }
}
